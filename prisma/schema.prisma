generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String       @id @default(uuid())
  name              String       @db.VarChar(255)
  phone             String?      @unique @db.VarChar(20)
  email             String       @unique @db.VarChar(255)
  profileImage      String?      @db.VarChar(500)
  profileCoverImage String?      @db.VarChar(500)
  address           String?      @db.VarChar(500)
  pinCode           String?      @db.VarChar(10)
  bio               String?
  password          String       @db.VarChar(255)
  isActive          Boolean      @default(true)
  countryCode       Int          @default(91)
  isPhoneVerified   Boolean      @default(false)
  isEmailVerified   Boolean      @default(false)
  createdAt         DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime     @updatedAt @db.Timestamptz(3)
  reviews           TourReview[]

  @@index([isActive, createdAt(sort: Desc)])
  @@index([email])
  @@index([phone])
  @@map("users")
}

model Tour {
  id                 String           @id @default(cuid())
  title              String           @db.VarChar(255)
  slug               String           @unique @db.VarChar(300)
  metatitle          String?          @db.VarChar(255)
  metadesc           String?          @db.VarChar(500)
  overview           String?
  description        String?
  durationDays       Int              @default(0) @db.SmallInt
  durationNights     Int              @default(0) @db.SmallInt
  price              Int              @default(0)
  discountPrice      Int?
  currency           String           @default("INR") @db.VarChar(3)
  minGroupSize       Int              @default(1) @db.SmallInt
  maxGroupSize       Int              @default(50) @db.SmallInt
  bestTime           String?          @db.VarChar(255)
  idealFor           String?          @db.VarChar(255)
  difficulty         String?          @db.VarChar(50)
  rating             Decimal          @default(0) @db.Decimal(3, 2)
  reviewCount        Int              @default(0)
  viewCount          Int              @default(0)
  bookingCount       Int              @default(0)
  isActive           Boolean          @default(true)
  isFeatured         Boolean          @default(false)
  cancellationPolicy String?
  travelTips         String?
  startCityId        String?
  createdAt          DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime         @updatedAt @db.Timestamptz(3)
  images             String[]
  highlights         String[]
  inclusions         String[]
  exclusions         String[]
  faqs               Faq[]
  reviews            TourReview[]
  cities             TourCity[]
  itinerary          TourItinerary[]
  priceGuide         TourPriceGuide[]
  themes             TourTheme[]
  startCity          City?            @relation("TourStartCity", fields: [startCityId], references: [id])

  @@index([isActive, isFeatured, rating(sort: Desc)])
  @@index([isActive, price, rating(sort: Desc)])
  @@index([isActive, createdAt(sort: Desc)])
  @@index([isActive, bookingCount(sort: Desc)])
  @@index([isActive, viewCount(sort: Desc)])
  @@index([startCityId, isActive, rating(sort: Desc)])
  @@index([durationDays, isActive, rating(sort: Desc)])
  @@index([slug])
  @@map("tours")
}

model TourPriceGuide {
  id     String @id @default(cuid())
  tourId String
  title  String @db.VarChar(255)
  value  Int    @default(0)
  order  Int    @default(0) @db.SmallInt
  tour   Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, order])
  @@index([tourId])
  @@map("tour_price_guide")
}

model Theme {
  id          String      @id @default(cuid())
  name        String      @db.VarChar(100)
  label       String      @db.VarChar(150)
  slug        String      @unique @db.VarChar(150)
  icon        String?     @db.VarChar(100)
  description String?
  imageUrl    String?     @db.VarChar(500)
  isActive    Boolean     @default(true)
  order       Int         @default(0) @db.SmallInt
  tourCount   Int         @default(0)
  createdAt   DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(3)
  tours       TourTheme[]

  @@index([slug])
  @@index([isActive, order])
  @@index([isActive, tourCount(sort: Desc)])
  @@map("themes")
}

model TourTheme {
  tourId    String
  themeId   String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  theme     Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@id([tourId, themeId])
  @@index([themeId])
  @@index([tourId])
  @@map("tour_themes")
}

model TourReview {
  id           String        @id @default(cuid())
  userId       String
  tourId       String
  rating       Int           @db.SmallInt
  title        String        @db.VarChar(255)
  comment      String
  isActive     Boolean       @default(true)
  isVerified   Boolean       @default(false)
  helpfulCount Int           @default(0)
  createdAt    DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(3)
  images       ReviewImage[]
  tour         Tour          @relation(fields: [tourId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tourId])
  @@index([tourId, isActive, rating(sort: Desc)])
  @@index([tourId, isActive, createdAt(sort: Desc)])
  @@index([tourId, isActive, helpfulCount(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([isActive, isVerified])
  @@map("reviews")
}

model ReviewImage {
  id         String     @id @default(cuid())
  reviewId   String
  key        String     @db.VarChar(500)
  url        String     @db.VarChar(1000)
  thumbnail  String?    @db.VarChar(1000)
  uploadedAt DateTime   @default(now()) @db.Timestamptz(3)
  review     TourReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_images")
}

model TourItinerary {
  id          String  @id @default(cuid())
  tourId      String
  day         Int     @db.SmallInt
  title       String  @db.VarChar(255)
  description String
  imageUrl    String? @db.VarChar(1000)
  tour        Tour    @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, day])
  @@index([tourId, day])
  @@map("tour_itinerary")
}

model TourCity {
  tourId    String
  cityId    String
  order     Int      @default(0) @db.SmallInt
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@id([tourId, cityId])
  @@index([cityId])
  @@index([tourId])
  @@map("tour_cities")
}

model City {
  id            String     @id @default(cuid())
  name          String     @db.VarChar(150)
  label         String     @db.VarChar(150)
  slug          String     @unique @db.VarChar(200)
  stateId       String?    @db.VarChar(100)
  stateName     String?    @db.VarChar(150)
  countryId     String?    @db.VarChar(100)
  countryName   String?    @db.VarChar(150)
  latitude      Decimal?   @db.Decimal(10, 8)
  longitude     Decimal?   @db.Decimal(11, 8)
  imageUrl      String?    @db.VarChar(500)
  description   String?
  isActive      Boolean    @default(true)
  tourCount     Int        @default(0)
  createdAt     DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime   @updatedAt @db.Timestamptz(3)
  tours         TourCity[]
  startingTours Tour[]     @relation("TourStartCity")

  @@index([slug])
  @@index([isActive, tourCount(sort: Desc)])
  @@index([isActive, name])
  @@index([stateId, isActive])
  @@index([countryId, isActive])
  @@map("cities")
}

model Faq {
  id        String        @id @default(cuid())
  tourId    String
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt DateTime      @updatedAt @db.Timestamptz(3)
  questions FaqQuestion[]
  tour      Tour          @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId, isActive])
  @@map("faqs")
}

model FaqQuestion {
  id       String @id @default(cuid())
  faqId    String
  question String
  answer   String
  order    Int    @db.SmallInt
  faq      Faq    @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([faqId, order])
  @@index([faqId])
  @@map("faq_questions")
}

model TravelGuideState {
  id        String            @id @default(cuid())
  name      String            @db.VarChar(150)
  slug      String?           @unique @db.VarChar(200)
  createdAt DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt DateTime          @updatedAt @db.Timestamptz(3)
  cities    TravelGuideCity[]
  data      TravelGuideData[]

  @@index([slug])
  @@index([name])
  @@map("travel_guide_states")
}

model TravelGuideCity {
  id        String            @id @default(cuid())
  name      String            @db.VarChar(150)
  slug      String?           @unique @db.VarChar(200)
  stateId   String
  stateName String            @db.VarChar(150)
  createdAt DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt DateTime          @updatedAt @db.Timestamptz(3)
  state     TravelGuideState  @relation(fields: [stateId], references: [id], onDelete: Cascade)
  data      TravelGuideData[]

  @@index([stateId])
  @@index([slug])
  @@index([name])
  @@map("travel_guide_cities")
}

model TravelGuideData {
  id                String           @id @default(cuid())
  cityId            String
  citySlug          String?          @db.VarChar(200)
  stateId           String
  stateSlug         String?          @db.VarChar(200)
  originalCityId    Int?
  menuId            Int?
  isActive          Boolean          @default(true)
  introduction      String?          @db.Text
  facts             String?          @db.Text
  foodAndDining     String?          @db.Text
  shopping          String?          @db.Text
  nearbyPlaces      String?          @db.Text
  gettingAround     String?          @db.Text
  historyCulture    String?          @db.Text
  otherDetails      String?          @db.Text
  bestTimeToVisit   String?          @db.VarChar(255)
  placesToSeeTop    String?          @db.Text
  placesToSeeBottom String?          @db.Text
  hotelDetails      String?          @db.Text
  cityImage         String?          @db.VarChar(500)
  createdAt         DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(3)
  city              TravelGuideCity  @relation(fields: [cityId], references: [id], onDelete: Cascade)
  state             TravelGuideState @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@unique([cityId, stateId])
  @@index([cityId])
  @@index([stateId])
  @@index([citySlug])
  @@index([stateSlug])
  @@index([isActive])
  @@map("travel_guide_data")
}

model Admin {
  id                 String    @id @default(uuid())
  name               String    @db.VarChar(255)
  email              String    @unique @db.VarChar(255)
  password           String    @db.VarChar(255)
  roleId             String
  isActive           Boolean   @default(true)
  lastLoginAt        DateTime? @db.Timestamptz(3)
  refreshToken       String?   @db.VarChar(500)
  refreshTokenExpiry DateTime? @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @db.Timestamptz(3)
  role               Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)

  // CRM Relations
  assignedLeads           Lead[]              @relation("AssignedLeads")
  performedActivities     LeadActivity[]      @relation("PerformedActivities")
  statusChanges           LeadStatusHistory[] @relation("StatusChanges")
  createdNotes            LeadNote[]          @relation("CreatedNotes")
  uploadedQuotations      LeadQuotation[]     @relation("UploadedQuotations")
  performedCommunications LeadCommunication[] @relation("PerformedCommunications")
  assignedReminders       LeadReminder[]      @relation("AssignedReminders")
  createdReminders        LeadReminder[]      @relation("CreatedReminders")

  @@index([email])
  @@index([isActive])
  @@index([roleId])
  @@map("admins")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique @db.VarChar(100)
  description String?      @db.Text
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(3)
  admins      Admin[]
  permissions Permission[]

  @@index([name])
  @@index([isActive])
  @@map("roles")
}

model Module {
  id          String       @id @default(cuid())
  name        String       @unique @db.VarChar(100)
  label       String       @db.VarChar(150)
  description String?      @db.Text
  icon        String?      @db.VarChar(100)
  order       Int          @default(0) @db.SmallInt
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(3)
  permissions Permission[]

  @@index([name])
  @@index([isActive, order])
  @@map("modules")
}

model Permission {
  id        String   @id @default(cuid())
  roleId    String
  moduleId  String
  view      Boolean  @default(false)
  create    Boolean  @default(false)
  edit      Boolean  @default(false)
  delete    Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId])
  @@index([roleId])
  @@index([moduleId])
  @@map("permissions")
}

// ============================================
// CRM ENUMS
// ============================================

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  QUOTED
  NEGOTIATING
  FOLLOW_UP_SCHEDULED
  CONFIRMED
  CLOSED_WON
  CLOSED_LOST
  NOT_INTERESTED
}

enum LeadSource {
  WEBSITE_FORM
  PHONE_CALL
  EMAIL
  WHATSAPP
  FACEBOOK
  INSTAGRAM
  GOOGLE_ADS
  REFERRAL
  WALK_IN
  TOUR_QUERY
  HOTEL_QUERY
  TRANSPORT_QUERY
  CONTACT_US
  OTHER
}

enum LeadPriority {
  HOT
  WARM
  COLD
}

enum LeadQuality {
  A
  B
  C
}

enum LeadServiceType {
  TOUR
  HOTEL
  TRANSPORT
  MIXED
}

enum CommunicationType {
  CALL
  EMAIL
  WHATSAPP
  SMS
  MEETING
  OTHER
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

enum ReminderType {
  FOLLOW_UP
  CALLBACK
  QUOTE_FOLLOW_UP
  GENERAL
}

// ============================================
// CRM CONFIGURATION MODELS
// ============================================

model LeadTag {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  label       String   @db.VarChar(150)
  color       String   @db.VarChar(7)
  icon        String?  @db.VarChar(50)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  order       Int      @default(0) @db.SmallInt
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
  leads       Lead[]

  @@index([isActive, order])
  @@index([name])
  @@map("lead_tags")
}

model LeadSourceMaster {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  label       String   @db.VarChar(150)
  icon        String?  @db.VarChar(50)
  color       String?  @db.VarChar(7)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  order       Int      @default(0) @db.SmallInt
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  @@index([isActive, order])
  @@index([name])
  @@map("lead_source_masters")
}

model LeadCategory {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  label       String   @db.VarChar(150)
  icon        String?  @db.VarChar(50)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  order       Int      @default(0) @db.SmallInt
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
  leads       Lead[]

  @@index([isActive, order])
  @@index([name])
  @@map("lead_categories")
}

// ============================================
// MAIN LEAD MODEL
// ============================================

model Lead {
  id              String           @id @default(cuid())
  referenceNumber String           @unique @db.VarChar(20)
  source          LeadSource
  status          LeadStatus       @default(NEW)
  priority        LeadPriority     @default(WARM)
  quality         LeadQuality?
  serviceType     LeadServiceType?

  // Customer Information
  fullName       String  @db.VarChar(255)
  email          String  @db.VarChar(255)
  phoneNumber    String? @db.VarChar(20)
  alternatePhone String? @db.VarChar(20)
  city           String? @db.VarChar(150)

  // Service Requirements
  destination       String?   @db.VarChar(255)
  travelStartDate   DateTime? @db.Timestamptz(3)
  travelEndDate     DateTime? @db.Timestamptz(3)
  numberOfTravelers Int?      @db.SmallInt
  numberOfAdults    Int?      @db.SmallInt
  numberOfChildren  Int?      @db.SmallInt
  budgetMin         Int?
  budgetMax         Int?
  specialRequests   String?   @db.Text

  // Classification
  tagId      String?
  tag        LeadTag?      @relation(fields: [tagId], references: [id], onDelete: SetNull)
  categoryId String?
  category   LeadCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Assignment
  assignedToId String?
  assignedTo   Admin?    @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedAt   DateTime? @db.Timestamptz(3)

  // Tracking & Metrics
  firstResponseAt       DateTime? @db.Timestamptz(3)
  responseTimeMinutes   Int?
  lastActivityAt        DateTime? @db.Timestamptz(3)
  nextFollowUpAt        DateTime? @db.Timestamptz(3)
  followUpCount         Int       @default(0)
  isOverdue             Boolean   @default(false)
  leadScore             Int       @default(0) @db.SmallInt
  conversionProbability Decimal?  @db.Decimal(5, 2)

  // Financial
  estimatedValue Int?
  actualValue    Int?

  // Closure
  lostReason String?   @db.Text
  closedAt   DateTime? @db.Timestamptz(3)

  // Legacy & Metadata
  details     Json?
  ipAddress   String?   @db.VarChar(50)
  userAgent   String?   @db.VarChar(500)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  contactedAt DateTime? @db.Timestamptz(3)

  // Relations
  activities     LeadActivity[]
  notes          LeadNote[]
  quotations     LeadQuotation[]
  communications LeadCommunication[]
  reminders      LeadReminder[]
  statusHistory  LeadStatusHistory[]

  @@index([source, status, createdAt(sort: Desc)])
  @@index([status, priority, createdAt(sort: Desc)])
  @@index([assignedToId, status, priority])
  @@index([priority, leadScore(sort: Desc)])
  @@index([nextFollowUpAt])
  @@index([isOverdue, assignedToId])
  @@index([email])
  @@index([referenceNumber])
  @@index([createdAt(sort: Desc)])
  @@index([tagId])
  @@index([categoryId])
  @@map("leads")
}

// ============================================
// LEAD ACTIVITY & HISTORY
// ============================================

model LeadActivity {
  id            String   @id @default(cuid())
  leadId        String
  activityType  String   @db.VarChar(50)
  description   String   @db.Text
  metadata      Json?
  performedById String?
  performedBy   Admin?   @relation("PerformedActivities", fields: [performedById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt(sort: Desc)])
  @@index([activityType])
  @@map("lead_activities")
}

model LeadStatusHistory {
  id          String   @id @default(cuid())
  leadId      String
  fromStatus  String?  @db.VarChar(50)
  toStatus    String   @db.VarChar(50)
  fromTag     String?  @db.VarChar(100)
  toTag       String?  @db.VarChar(100)
  notes       String?  @db.Text
  changedById String
  changedBy   Admin    @relation("StatusChanges", fields: [changedById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt(sort: Desc)])
  @@map("lead_status_history")
}

// ============================================
// NOTES & DOCUMENTATION
// ============================================

model LeadNote {
  id          String   @id @default(cuid())
  leadId      String
  content     String   @db.Text
  attachments String[]
  createdById String
  createdBy   Admin    @relation("CreatedNotes", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt(sort: Desc)])
  @@map("lead_notes")
}

// ============================================
// QUOTATIONS
// ============================================

model LeadQuotation {
  id            String    @id @default(cuid())
  leadId        String
  version       Int       @db.SmallInt
  fileName      String    @db.VarChar(255)
  fileKey       String    @db.VarChar(500)
  fileUrl       String    @db.VarChar(1000)
  fileSize      Int
  fileType      String    @db.VarChar(50)
  description   String?   @db.Text
  amount        Int?
  isAccepted    Boolean   @default(false)
  acceptedAt    DateTime? @db.Timestamptz(3)
  sentViaEmail  Boolean   @default(false)
  emailOpenedAt DateTime? @db.Timestamptz(3)
  uploadedById  String
  uploadedBy    Admin     @relation("UploadedQuotations", fields: [uploadedById], references: [id], onDelete: Restrict)
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, version])
  @@index([leadId, createdAt(sort: Desc)])
  @@index([isAccepted])
  @@map("lead_quotations")
}

// ============================================
// COMMUNICATIONS
// ============================================

model LeadCommunication {
  id            String                 @id @default(cuid())
  leadId        String
  type          CommunicationType
  direction     CommunicationDirection
  subject       String?                @db.VarChar(255)
  content       String?                @db.Text
  duration      Int?
  status        String?                @db.VarChar(50)
  metadata      Json?
  performedById String?
  performedBy   Admin?                 @relation("PerformedCommunications", fields: [performedById], references: [id], onDelete: SetNull)
  createdAt     DateTime               @default(now()) @db.Timestamptz(3)
  lead          Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@map("lead_communications")
}

// ============================================
// REMINDERS & FOLLOW-UPS
// ============================================

model LeadReminder {
  id               String       @id @default(cuid())
  leadId           String
  scheduledFor     DateTime     @db.Timestamptz(3)
  reminderType     ReminderType
  notes            String?      @db.Text
  isCompleted      Boolean      @default(false)
  completedAt      DateTime?    @db.Timestamptz(3)
  isSnoozed        Boolean      @default(false)
  snoozeReason     String?      @db.Text
  snoozedUntil     DateTime?    @db.Timestamptz(3)
  notificationSent Boolean      @default(false)
  assignedToId     String
  assignedTo       Admin        @relation("AssignedReminders", fields: [assignedToId], references: [id], onDelete: Restrict)
  createdById      String
  createdBy        Admin        @relation("CreatedReminders", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt        DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(3)
  lead             Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, scheduledFor])
  @@index([assignedToId, isCompleted, scheduledFor])
  @@index([scheduledFor, isCompleted])
  @@map("lead_reminders")
}

model PoiCategory {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  monumentCount Int      @default(0) @map("monument_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([monumentCount])
  @@map("poi_categories")
}

model PoiMetadata {
  id        String   @id @default(uuid())
  key       String   @unique
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("poi_metadata")
}

model PoiState {
  id            String    @id @default(uuid())
  slug          String    @unique
  name          String
  monumentCount Int       @default(0) @map("monument_count")
  cityCount     Int       @default(0) @map("city_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  cities        PoiCity[]

  @@index([slug])
  @@index([name])
  @@map("poi_states")
}

model PoiCity {
  id            String        @id @default(uuid())
  slug          String
  name          String
  stateId       String        @map("state_id")
  monumentCount Int           @default(0) @map("monument_count")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  state         PoiState      @relation(fields: [stateId], references: [id], onDelete: Cascade)
  monuments     PoiMonument[]

  @@unique([stateId, slug])
  @@index([slug])
  @@index([stateId])
  @@map("poi_cities")
}

model PoiMonument {
  id           String   @id @default(uuid())
  slug         String   @unique
  monumentName String   @map("monument_name")
  cityId       String   @map("city_id")
  typeofPlace  String?  @map("type_of_place")
  description  String?  @db.Text
  besttime     String?  @map("best_time")
  openingtime  String?  @map("opening_time")
  clossingtime String?  @map("closing_time")
  weeklyoff    String?  @map("weekly_off")
  entryFees    Json?    @map("entry_fees")
  weather      Json?
  connectivity Json?
  location     Json?
  rating       Float?
  totalRatings Int?     @default(0) @map("total_ratings")
  website      String?
  phone        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  city         PoiCity  @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([cityId])
  @@index([monumentName])
  @@index([typeofPlace])
  @@map("poi_monuments")
}

model HeroSlide {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(255)
  subtitle  String?  @db.VarChar(500)
  location  String?  @db.VarChar(150)
  duration  String?  @db.VarChar(100)
  imageKey  String   @db.VarChar(500)
  imageUrl  String   @db.VarChar(1000)
  ctaText   String   @default("Explore Tours") @db.VarChar(100)
  ctaLink   String   @default("/india-tour-packages") @db.VarChar(500)
  isActive  Boolean  @default(true)
  order     Int      @default(0) @db.SmallInt
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([order])
  @@index([isActive, order])
  @@index([order])
  @@map("hero_slides")
}
